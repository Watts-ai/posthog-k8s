# Required — your domain (used for SITE_URL, CORS, etc.)
DOMAIN=posthog.example.com

# Required — generate with: openssl rand -hex 28
POSTHOG_SECRET=

# Required — generate with: openssl rand -hex 16
ENCRYPTION_SALT_KEYS=

# Image tags (defaults work, pin for stability)
# REGISTRY_URL=posthog/posthog
# POSTHOG_APP_TAG=latest
# POSTHOG_NODE_TAG=latest

# Set to override the default https://$DOMAIN (e.g. for local HTTP testing)
# SITE_URL=http://localhost:8000

# Set to false when not using TLS (e.g. local testing without a proxy)
# SECURE_COOKIES=false

# Set to true to disable anonymous telemetry to PostHog
# OPT_OUT_CAPTURE=false
